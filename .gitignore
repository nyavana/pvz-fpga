# AI tool config (keep CLAUDE.md tracked — it's project instructions)
.claude/
.codex/
.gemini/

# OS junk
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*~

# ---------- FPGA / Quartus build artifacts ----------
# Quartus compilation databases (regenerated every build)
hw/db/
hw/incremental_db/

# Quartus build outputs (reports, bitstreams, pinouts)
hw/output_files/
hw/*.qws
hw/*.bak

# Platform Designer generated HDL & metadata (regenerated by `make qsys`)
hw/soc_system/

# HPS ISW handoff (generated by Platform Designer for preloader/SDRAM)
hw/hps_isw_handoff/

# Generated device-tree, system-info, and board-info files
hw/soc_system.dtb
hw/soc_system.dts
hw/soc_system.sopcinfo
hw/soc_system.tcl
hw/soc_system_board_info.xml

# Quartus pin-model and SDRAM summaries
hw/c5_pin_model_dump.txt
hw/hps_sdram_p0_all_pins.txt
hw/hps_sdram_p0_summary.csv

# ---------- Software build artifacts ----------
sw/*.o
sw/*.ko
sw/*.mod
sw/*.mod.c
sw/.*.cmd
sw/modules.order
sw/Module.symvers
sw/.tmp_versions/
sw/pvz
sw/test/test_game
sw/test/test_input
sw/test/test_shapes
